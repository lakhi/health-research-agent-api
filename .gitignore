# See https://help.github.com/ignore-files/ for more about ignoring files.

.DS_Store

# Generated reports
reports/

# Cache
.mypy_cache
*__pycache__*
*.egg-info
*.pyc
*.pytest_cache
*.ruff_cache
*.cache*
*.config*

# Machine specific
.idea
.vscode
.claude/settings.local.json

# Bicep param files (contain secret values, never commit)
**/*.bicepparam

# Ignore .env files
.env
.env.local
.env.azure
.env.production
.envrc

# ignore storage dir
/storage

# PDF cache for NEX knowledge base (persisted across container restarts via bind mount)
/nex_pdfs_cache
db/sqlite_data.db

# ignore dist dir
dist

# ignore virtualenvs
.venv*
venv*

# eval results (generated)
/results

# Copy to .env and fill in real values. .env is gitignored.

# Project Configuration — uncomment exactly one
# PROJECT_NAME=vax-study
# PROJECT_NAME=hex-gig
# PROJECT_NAME=ssc-psych
LOAD_HEX_GIG_KNOWLEDGE=false
# false = skip scraping/embedding SSC knowledge at startup (data persists in Postgres);
# set true (or unset) for the first load or to pick up new documents from the SSC site
LOAD_SSC_PSYCH_KNOWLEDGE=false

# Local Development Database Configuration (Docker Postgres)
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

AGNO_API_KEY=

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_ENDPOINT_GPT_5_MINI=
AZURE_EMBEDDER_OPENAI_API_KEY=
AZURE_EMBEDDER_OPENAI_ENDPOINT=
AZURE_EMBEDDER_DEPLOYMENT=
AZURE_EMBEDDER_OPENAI_API_VERSION=

# Docker Image Configuration
IMAGE_NAME=health-research-agent-api
IMAGE_TAG=latest

# Budget Configuration (required for hex-gig and ssc-psych projects — see api/settings.py)
DAILY_BUDGET_EUR=
MODEL_PRICING_INPUT_EUR=
MODEL_PRICING_OUTPUT_EUR=

# u:Cloud (Nextcloud) Configuration (hex_gig agent research papers)
UCLOUD_SHARE_TOKEN=
UCLOUD_SHARE_PASSWORD=
